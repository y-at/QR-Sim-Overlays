<UserControl x:Class="QRO.Views.OverlaySelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QRO.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <GroupBox Header="Overlays" Grid.Column="1" Grid.Row="0" Margin="5">
            <StackPanel>
                <Button Content="Show Input Traces" Click="ShowInputTraces_Click" Margin="5" Padding="10,5"/>
                <Button Content="Show Attitude" Click="ShowAttitude_Click" Margin="5" Padding="10,5"/>
                <Button Content="Show Wind Direction Compass" Click="ShowWindDirectionCompass_Click" Margin="5" Padding="10,5"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>
