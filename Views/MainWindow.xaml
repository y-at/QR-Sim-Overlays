<Window x:Class="QRO.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:local="clr-namespace:QRO"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding QRO}" Height="350" Width="525" >
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ContentControl Name="Sidebar"
                            Grid.Column="0"
                            prism:RegionManager.RegionName="{x:Static local:UIRegions.SidebarRegion}"/>

            <ContentControl Name="Content"
                            Grid.Column="1"
                            prism:RegionManager.RegionName="{x:Static local:UIRegions.ContentRegion}"/>
        </Grid>
    </Grid>
</Window>
